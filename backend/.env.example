# ── Django ──────────────────────────────────────────────────
SECRET_KEY=your-long-random-secret-key-here-at-least-50-chars
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── Database ─────────────────────────────────────────────────
# Leave blank to use SQLite (dev only)
DATABASE_URL=postgresql://pylearn:yourpassword@db:5432/pylearn

# ── Cache / Queue ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── AI ───────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
# Leave blank to use mock responses (for dev/demo)
OPENAI_API_KEY=sk-...

# ── Code execution ────────────────────────────────────────────
CODE_EXECUTION_TIMEOUT=5
CODE_MAX_SIZE_KB=50
